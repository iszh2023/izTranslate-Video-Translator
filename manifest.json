{
  "manifest_version": 3,
  "name": "iTranslate Video Translator",
  "version": "0.1.1",
  "description": "Reads video captions and can speak them while the video plays (completely free; no external translation APIs).",
  "permissions": ["storage", "activeTab", "tts"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Video Translator",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
